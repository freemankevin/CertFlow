#==============================================
# SSL证书自动续期配置文件示例
# 复制此文件为 ssl-cert.conf 并修改配置
#==============================================

#==============================================
# 核心配置（必填）
#==============================================

# 域名配置（支持多域名，空格或逗号分隔）
# 示例:
#   单域名: DOMAINS="example.com"
#   多域名: DOMAINS="example.com,www.example.com"
#   泛域名: DOMAINS="example.com,*.example.com" (需要 DNS API 模式)
DOMAINS="your.domain.com"

# 路径配置
BASE_DIR="/data/opt/installmiddleware"
CERT_DIR="${BASE_DIR}/certs"
WEBROOT_DIR="${BASE_DIR}/html"

# acme.sh 路径
ACME_SH="${HOME}/.acme.sh/acme.sh"

#==============================================
# 验证模式配置
#==============================================

# 验证模式: "webroot" 或 "dns"
# - webroot: 通过 HTTP 验证，需要在 WEBROOT_DIR 放置验证文件
#            适用于大多数场景，需要 Web 服务器支持
# - dns: 通过 DNS API 验证，支持泛域名证书
#         需要配置 DNS API 提供商和密钥
VERIFY_MODE="webroot"

# DNS API 配置（仅 VERIFY_MODE=dns 时需要）
# 支持的提供商:
#   - dns_ali: 阿里云 DNS
#   - dns_cf:  Cloudflare DNS
#   - dns_dp:  DNSPod (腾讯云)
#   - dns_aws: AWS Route53
# 完整列表: https://github.com/acmesh-official/acme.sh/wiki/dnsapi
DNS_API_PROVIDER=""

# DNS API 密钥（根据服务商配置）
# 阿里云示例:
#   DNS_API_PROVIDER="dns_ali"
#   DNS_API_KEY="your-access-key-id"
#   DNS_API_SECRET="your-access-key-secret"
#
# Cloudflare 示例:
#   DNS_API_PROVIDER="dns_cf"
#   DNS_API_KEY="your-api-key"
#   DNS_API_SECRET="your-email@example.com"
DNS_API_KEY=""
DNS_API_SECRET=""

#==============================================
# 重载配置
#==============================================

# 证书更新后执行的命令
# 示例:
#   Docker: RELOAD_CMD="docker restart nginx"
#   Systemd: RELOAD_CMD="systemctl reload nginx"
#   自定义: RELOAD_CMD="/usr/local/bin/reload-nginx.sh"
RELOAD_CMD="docker restart nginx"

#==============================================
# 通知配置（可选）
#==============================================

# Webhook 通知 URL
# 留空则不发送通知
# 企业微信: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY
# 钉钉:     https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
# Slack:    https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Discord:  https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
WEBHOOK_URL=""

# Webhook 类型: "wechat" | "dingtalk" | "slack" | "discord" | "custom"
# - wechat:   企业微信机器人
# - dingtalk: 钉钉机器人
# - slack:    Slack Incoming Webhook
# - discord:  Discord Webhook
# - custom:   自定义 JSON 格式
WEBHOOK_TYPE="wechat"

#==============================================
# 高级配置（可选）
#==============================================

# 是否启用日志文件
# 启用后日志将写入 LOG_DIR 目录
ENABLE_LOG=false
LOG_DIR="${BASE_DIR}/logs"

# Dry-run 模式（测试模式）
# 启用后不会实际申请证书，仅模拟流程
DRY_RUN=false

# 证书密钥长度
# 可选值: 2048 | 3072 | 4096
# 推荐使用 2048，安全性足够且性能更好
CERT_KEY_LENGTH="2048"

# CA 服务器
# - letsencrypt: Let's Encrypt (推荐)
# - zerossl:     ZeroSSL
# - buypass:     Buypass
CA_SERVER="letsencrypt"

# 证书续期阈值（天数）
# 只有证书有效期少于此天数时才会续期
RENEW_THRESHOLD_DAYS=30

# 是否跳过域名解析检查
# 启用后不验证域名是否解析到本机
# 适用于使用 CDN 或负载均衡的场景
SKIP_DNS_CHECK=false